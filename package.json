{
  "name": "kirby-bucket",
  "version": "3.0.0",
  "description": "Kirby Bucket is a simple developer theme and boilerplate for the Kirby CMS.",
  "author": "Manuel Deutsch",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manueldeutsch/kirby-bucket.git"
  },
  "scripts": {
    "dev": "parcel watch ./assets/css/main.css ./assets/js/main.js --dist-dir ./assets/dist --public-url .",
    "build": "parcel build --no-content-hash --no-source-maps ./assets/css/main.css ./assets/js/main.js --dist-dir ./assets/dist --public-url .",
    "clean": "rm -rf .parcel-cache assets/dist"
  },
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "devDependencies": {
    "@parcel/transformer-image": "^2.13.3",
    "parcel": "^2.13.3"
  },
  "dependencies": {},
  "prettier": {
    "printWidth": 120
  },
  "@parcel/transformer-css": {
    "drafts": {
      "nesting": true
    }
  }
}
